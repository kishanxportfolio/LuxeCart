<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= product.name %> | LuxeCart
    </title>
    <link rel="stylesheet" href="/output.css">
    <style>
        .luxe-font {
            font-variant: small-caps;
        }
        input[type="radio"]:checked+label {
            background-color: black;
            color: white;
            border-color: black;
            transform: scale(0.95);
        }

        .custom-scrollbar::-webkit-scrollbar {
            height: 4px;
        }

        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #eee;
            border-radius: 10px;
        }
    </style>
</head>

<body class="bg-[#fcfcfc] luxe-font scroll-smooth text-gray-900">

    <%- include('../partials/nav') %>

        <main class="max-w-screen-2xl mx-auto px-6 md:px-16 py-20 bg-white shadow-sm rounded-b-[60px]">
            <nav class="flex text-[10px] uppercase tracking-[0.4em] text-gray-400 mb-12 gap-2 font-black">
                <a href="/" class="hover:text-black transition">Home</a> /
                <a href="/shop/<%= product.category %>" class="hover:text-black transition">
                    <%= product.category %>
                </a> /
                <span class="text-pink-600 italic">
                    <%= product.name %>
                </span>
            </nav>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-20 items-start">

                <div class="flex flex-col md:flex-row gap-6">
                    <div
                        class="flex md:flex-col gap-4 order-2 md:order-1 overflow-x-auto custom-scrollbar md:overflow-visible pb-4 md:pb-0">
                        <% for(let i=0; i<3; i++) { %>
                            <div
                                class="w-20 h-20 md:w-24 md:h-24 rounded-2xl overflow-hidden border-2 border-transparent bg-gray-50 cursor-pointer hover:border-pink-600 transition shrink-0">
                                <img src="<%= product.image %>"
                                    class="w-full h-full object-contain p-2 opacity-60 hover:opacity-100 transition">
                            </div>
                            <% } %>
                    </div>

                    <div class="flex-grow order-1 md:order-2">
                        <div
                            class="group relative overflow-hidden rounded-[40px] bg-[#f9fafb] aspect-[3/4] border border-gray-100 flex items-center justify-center shadow-inner">
                            <img src="<%= product.image %>" id="mainImage"
                                class="w-full h-full object-contain p-12 transition-transform duration-700 group-hover:scale-125 cursor-crosshair">

                            <% if(product.price> product.offerPrice) { %>
                                <div
                                    class="absolute top-8 left-8 bg-black text-white text-[10px] font-black px-4 py-2 rounded-full uppercase tracking-widest shadow-xl">
                                    -<%= Math.round(((product.price - product.offerPrice)/product.price)*100) %>% Off
                                </div>
                                <% } %>
                        </div>
                    </div>
                </div>

                <div class="flex flex-col space-y-12">
                    <div class="space-y-6">
                        <span
                            class="inline-block px-4 py-1.5 bg-pink-50 text-pink-600 text-[10px] font-black uppercase tracking-[0.3em] rounded-full">
                            Premium <%= product.category %> Collection
                        </span>
                        <h1
                            class="text-5xl md:text-7xl font-black uppercase tracking-tighter text-black leading-[0.9] italic">
                            <%= product.name %>
                        </h1>

                        <div class="flex items-center gap-6 pt-4">
                            <div class="flex flex-col">
                                <span class="text-5xl font-black text-black tracking-tight leading-none">$<%=
                                        product.offerPrice %></span>
                                <% if(product.price> product.offerPrice) { %>
                                    <span class="text-xl text-gray-300 line-through font-light italic mt-2">$<%=
                                            product.price %></span>
                                    <% } %>
                            </div>
                        </div>
                    </div>

                    <div class="space-y-6">
                        <% let pType=(product.type || "" ).toLowerCase().trim(); let pSubCat=(product.subCategory || ""
                            ).toLowerCase().trim(); let pMainCat=(product.category || "" ).toLowerCase().trim(); let
                            sizes=[]; if (pType && pType.includes('cloth')) { sizes=['S', 'M' , 'L' , 'XL' , 'XXL' ]; }
                            if (pType && pType.includes('foot')) { sizes=['7', '8' , '9' , '10' , '11' ]; } if (pSubCat
                            && pSubCat.includes('inner')) { sizes=['80cm', '85cm' , '90cm' , '95cm' ]; } %>
                            <% if (sizes.length> 0) { %>
                                <div class="flex justify-between items-center">
                                    <p class="text-[10px] font-black uppercase tracking-[0.4em] text-gray-400">Select
                                        Size</p>
                                    <a href="#"
                                        class="text-[10px] font-bold underline text-gray-400 hover:text-black transition">Size
                                        Guide</a>
                                </div>
                                <div class="flex flex-wrap gap-4">
                                    <% sizes.forEach(size=> { %>
                                        <input type="radio" id="size-<%= size %>" name="size" class="hidden" required>
                                        <label for="size-<%= size %>"
                                            class="w-16 h-16 border-2 border-gray-100 rounded-2xl flex items-center justify-center text-xs font-black bg-white peer-checked:bg-black peer-checked:text-white peer-checked:border-black transition-all cursor-pointer shadow-sm hover:border-gray-300">
                                            <%= size %>
                                        </label>
                                        <% }) %>
                                </div>
                                <% } else { %>
                                    <div class="p-4 bg-gray-50 rounded-2xl border border-dashed border-gray-200">
                                        <p
                                            class="text-[10px] font-black uppercase tracking-[0.4em] text-gray-400 font-sans">
                                            Standard Size / One Size Fits All</p>
                                    </div>
                                    <% } %>
                    </div>

                    <div class="flex gap-4 pt-4">
                        <form action="/add-to-cart/<%= product._id %>" method="POST" class="flex-grow">
                            <button type="submit"
                                class="w-full bg-black text-white py-6 rounded-2xl font-black uppercase tracking-[0.3em] text-xs hover:bg-pink-600 transition-all shadow-2xl transform active:scale-95">
                                Add to Shopping Bag
                            </button>
                        </form>
                    </div>

                    <div class="space-y-4 pt-10 border-t border-gray-100">
                        <details
                            class="group bg-gray-50 p-8 rounded-3xl border border-transparent hover:border-gray-200 transition-all"
                            open>
                            <summary
                                class="flex justify-between items-center cursor-pointer text-xs font-black uppercase tracking-widest text-black list-none">
                                Description & Fit <span
                                    class="group-open:rotate-45 transition-transform text-xl">+</span>
                            </summary>
                            <p class="text-gray-500 text-sm leading-relaxed mt-6 font-medium italic opacity-80">
                                <%= product.description %>
                            </p>
                        </details>
                    </div>
                </div>
            </div>
        </main>

        <section class="max-w-screen-2xl mx-auto px-6 md:px-16 py-32 border-b border-gray-100">
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-20">
                <div class="space-y-8">
                    <h3 class="text-3xl font-black uppercase italic tracking-tighter text-black leading-none">Ratings
                        <span class="text-pink-600">&</span> Reviews
                    </h3>
                    <div class="flex items-center gap-6">
                        <div class="text-7xl font-black text-black tracking-tighter">4.5</div>
                        <div class="flex flex-col gap-1">
                            <div class="flex text-pink-600 text-xl tracking-tight">★★★★★</div>
                            <span class="text-[10px] font-black text-gray-300 uppercase tracking-widest italic">128
                                Verified Purchases</span>
                        </div>
                    </div>
                    <div class="space-y-4 pt-4 border-t border-gray-50">
                        <% [5, 4, 3, 2, 1].forEach((star, index)=> {
                            let width = [85, 12, 2, 1, 0][index];
                            %>
                            <div class="flex items-center gap-4 group cursor-pointer">
                                <span class="text-[10px] font-black w-4 opacity-40 group-hover:opacity-100 transition">
                                    <%= star %>★
                                </span>
                                <div class="flex-grow h-1.5 bg-gray-100 rounded-full overflow-hidden">
                                    <div class="h-full bg-black rounded-full transition-all duration-700 group-hover:bg-pink-600"
                                        style="width: <%= width %>%"></div>
                                </div>
                                <span
                                    class="text-[10px] font-black text-gray-300 w-8 group-hover:text-black transition">
                                    <%= width %>%
                                </span>
                            </div>
                            <% }) %>
                    </div>
                </div>

                <div class="lg:col-span-2 flex flex-col gap-12">
                    <div class="flex justify-between items-center border-b border-gray-50 pb-8">
                        <h4 class="text-[10px] font-black uppercase tracking-[0.4em] text-black">Top Customer Feedback
                        </h4>
                        <button
                            class="bg-black text-white px-8 py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-pink-600 transition shadow-xl">Write
                            Experience</button>
                    </div>
                    <div class="group space-y-6 pb-12 border-b border-gray-50 last:border-0">
                        <div class="flex justify-between items-start">
                            <div class="flex items-center gap-4">
                                <div
                                    class="w-12 h-12 bg-[#1e232f] text-white flex items-center justify-center rounded-2xl font-black text-xs">
                                    KK</div>
                                <div>
                                    <p class="text-xs font-black uppercase italic tracking-tight text-black">Krishna
                                         Verma</p>
                                    <p
                                        class="text-[9px] text-gray-400 font-bold uppercase tracking-widest flex items-center gap-2">
                                        <span class="text-green-500 font-black italic">✓ Verified</span> • 2 Hours Ago
                                    </p>
                                </div>
                            </div>
                            <div class="flex text-pink-600 text-[10px] gap-0.5">★★★★★</div>
                        </div>
                        <p class="text-gray-500 text-sm leading-relaxed italic font-medium opacity-80">"Quality feels
                            amazing. Best purchase of 2026 so far!"</p>
                    </div>
                </div>
            </div>
        </section>

        <section class="max-w-screen-2xl mx-auto px-6 md:px-16 py-24">
            <div class="flex justify-between items-end mb-16">
                <h2 class="text-5xl font-black uppercase italic tracking-tighter">You might also <span
                        class="text-pink-600">like</span></h2>
                <a href="/shop/all"
                    class="text-xs font-black border-b-2 border-black pb-1 uppercase tracking-widest hover:text-pink-600 hover:border-pink-600 transition">View
                    All</a>
            </div>
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-8">
                <% if(typeof relatedProducts !=='undefined' ) { %>
                    <% relatedProducts.forEach(item=> { %>
                        <a href="/product/<%= item._id %>" class="group flex flex-col">
                            <div
                                class="relative overflow-hidden rounded-[40px] aspect-[3/4] bg-gray-50 border border-gray-100 p-6 transition-all hover:shadow-2xl hover:bg-white">
                                <img src="<%= item.image %>"
                                    class="w-full h-full object-contain mix-blend-multiply group-hover:scale-110 transition duration-700">
                            </div>
                            <div class="mt-6 space-y-2 px-2">
                                <h3 class="text-[11px] font-black text-gray-400 uppercase tracking-widest">
                                    <%= item.category %>
                                </h3>
                                <h4
                                    class="text-sm font-black text-black uppercase tracking-tighter line-clamp-1 italic">
                                    <%= item.name %>
                                </h4>
                                <div class="flex items-center gap-3">
                                    <span class="text-xl font-black">$<%= item.offerPrice %></span>
                                    <span class="text-xs text-gray-300 line-through italic font-light">$<%= item.price
                                            %></span>
                                </div>
                            </div>
                        </a>
                        <% }) %>
                            <% } %>
            </div>
        </section>
        <button onclick="window.scrollTo({top:0, behavior:'smooth'})"
            class="flex items-center gap-3 mx-auto my-20 px-10 py-4 bg-black text-white text-xs font-bold rounded-full 
                   shadow-2xl hover:bg-pink-700 hover:-translate-y-2 transition-all duration-500 uppercase tracking-widest">
            <span>↑</span>
            <span>Back to Top</span>
        </button>
        <%- include('../partials/footer') %>

</body>

</html>