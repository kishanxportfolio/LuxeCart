<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LuxeCart | Premium Collection</title>
    <link rel="stylesheet" href="/output.css">
    <style>
        .collection-font {
            font-variant: small-caps;
        }

        .glass-effect {
            background: rgba(255, 255, 255, 0.1);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.2);
        }
    </style>
</head>

<body class="bg-[#fafafa] collection-font text-gray-900">
    <%- include('../partials/nav') %>

        <section class="max-w-7xl mx-auto px-6 md:px-10 py-16">
            <div class="text-center mb-16">
                <h1 class="text-4xl md:text-6xl font-black mb-4 tracking-tighter [font-variant:small-caps] italic">
                    Our CollecTion
                </h1>
                <div class="w-24 h-1 bg-black mx-auto"></div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-10">
                <a href="/shop/men" class="group relative block overflow-hidden rounded-3xl aspect-[16/10] shadow-2xl">
                    <img src="/imgs/men/men.jpg" alt="Men"
                        class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                    <div class="absolute bottom-8 left-8">
                        <span class="text-xs text-white/70 uppercase tracking-widest mb-2 block">Premium Wear</span>
                        <h2 class="text-white text-3xl md:text-4xl font-bold tracking-tight">Men Collection</h2>
                        <div
                            class="mt-4 flex items-center text-white text-sm font-bold group-hover:gap-4 transition-all">
                            EXPLORE NOW <span class="ml-2">→</span>
                        </div>
                    </div>
                </a>

                <a href="/shop/women"
                    class="group relative block overflow-hidden rounded-3xl aspect-[16/10] shadow-2xl">
                    <img src="/imgs/women/women.jpg" alt="Women"
                        class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110">
                    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                    <div class="absolute bottom-8 left-8">
                        <span class="text-xs text-white/70 uppercase tracking-widest mb-2 block">Luxury Style</span>
                        <h2 class="text-white text-3xl md:text-4xl font-bold tracking-tight">Women Collection</h2>
                        <div
                            class="mt-4 flex items-center text-white text-sm font-bold group-hover:gap-4 transition-all">
                            EXPLORE NOW <span class="ml-2">→</span>
                        </div>
                    </div>
                </a>
            </div>
        </section>

        <section class="max-w-7xl mx-auto py-20 px-6">
            <% categories.forEach(cat=> { %>
                <div class="mb-20">
                    <div class="flex items-center gap-6 mb-10">
                        <h2
                            class="text-2xl font-bold uppercase tracking-widest whitespace-nowrap italic underline underline-offset-8 decoration-pink-600">
                            <%= cat.name %>
                        </h2>
                        <div class="flex-grow h-[1px] bg-gray-200"></div>
                        <a href="/shop/<%= cat.key %>"
                            class="group flex items-center gap-2 text-xs font-bold uppercase hover:text-pink-600 transition">
                            View All <span class="group-hover:translate-x-1 transition-transform">→</span>
                        </a>
                    </div>

                    <div class="grid grid-cols-2 md:grid-cols-4 gap-x-6 gap-y-12">
                        <% data[cat.key].forEach(product=> { %>
                            <div class="group flex flex-col">
                                <div
                                    class="relative overflow-hidden rounded-2xl aspect-[3/4] bg-white border border-gray-100 shadow-sm transition-all hover:shadow-xl">
                                    <img src="<%= product.image %>" alt="<%= product.name %>"
                                        class="w-full h-full object-contain p-6 transition-transform duration-500 group-hover:scale-110">

                                    <div
                                        class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                        <a href="/shop/<%= cat.key %>"
                                            class="glass-effect text-white text-[10px] font-bold py-2 px-6 rounded-full tracking-widest">
                                            QUICK LOOK
                                        </a>
                                    </div>
                                </div>

                                <div class="mt-4 flex flex-col items-center text-center">
                                    <h3 class="text-sm font-bold text-gray-800 line-clamp-1 h-5 px-2 mb-1">
                                        <%= product.name %>
                                    </h3>
                                    <a href="/shop/<%= cat.key %>"
                                        class="text-[10px] font-bold text-pink-600 hover:text-black transition-colors uppercase tracking-widest">
                                        Shop Collection
                                    </a>
                                </div>
                            </div>
                            <% }) %>
                    </div>
                </div>
                <% }) %>
        </section>

        <button onclick="window.scrollTo({top:0, behavior:'smooth'})"
            class="flex items-center gap-3 mx-auto my-20 px-10 py-4 bg-black text-white text-xs font-bold rounded-full 
                   shadow-2xl hover:bg-pink-700 hover:-translate-y-2 transition-all duration-500 uppercase tracking-widest">
            <span>↑</span>
            <span>Back to Top</span>
        </button>

        <%- include('../partials/footer') %>
</body>

</html>