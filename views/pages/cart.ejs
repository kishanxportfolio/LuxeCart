<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>LuxeCart | Your Shopping Bag</title>
    <link rel="stylesheet" href="/output.css">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css" rel="stylesheet" />
</head>

<body class="bg-black text-white font-sans selection:bg-pink-600">

    <%- include('../partials/nav') %>

        <div class="max-w-7xl mx-auto px-6 py-12">
            <h1 class="text-4xl font-black  [font-variant:small-caps]  tracking-tighter italic mb-10">
                Your <span class="text-pink-600">Shopping Bag</span>
            </h1>

            <div class="flex flex-col lg:flex-row gap-12">

                <!-- LEFT SIDE -->
                <div class="flex-1 space-y-6">

                    <% let total=0; if (cart && cart.items) { cart.items.forEach(item=> {
                        total += item.productId.offerPrice * item.quantity;
                        });
                        }
                        %>

                        <% if (cart && cart.items.length> 0) { %>

                            <% cart.items.forEach(item=> { %>

                                <div
                                    class="flex items-center gap-6 bg-zinc-900/50 border border-zinc-800 p-6 rounded-2xl group hover:border-zinc-700 transition-all">

                                    <div class="w-24 h-32 bg-zinc-800 rounded-xl overflow-hidden shrink-0">
                                        <img src="<%= item.productId.image %>"
                                            class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                                    </div>

                                    <div class="flex-grow py-4">
                                        <div class="flex justify-between items-start">
                                            <div>
                                                <h3 class="font-black uppercase tracking-wider text-lg">
                                                    <%= item.productId.name %>
                                                </h3>
                                                <p
                                                    class="text-zinc-500 text-xs uppercase font-bold tracking-widest mt-1">
                                                    Category: <%= item.productId.category %>
                                                </p>
                                            </div>
                                        </div>

                                        <div class="flex justify-between items-end mt-6 flex-wrap">
                                            <form action="/cart/update/<%= item.productId._id %>" method="GET">
                                                <div
                                                    class="flex items-center border border-zinc-800 rounded-full px-3 py-1 gap-3 bg-zinc-900/50 w-fit ">

                                                    <button type="submit" name="action" value="decrease"
                                                        class="w-8 h-8 flex items-center justify-center rounded-full hover:bg-zinc-800 text-zinc-400 hover:text-white transition-all active:scale-90 font-bold text-lg">
                                                        -
                                                    </button>

                                                    <div class="flex flex-col items-center leading-tight px-2">
                                                        <span
                                                            class="text-[10px] uppercase tracking-widest text-zinc-500 font-bold">Qty</span>
                                                        <span class="text-sm font-black text-white">
                                                            <%= item.quantity %>
                                                        </span>
                                                    </div>

                                                    <button type="submit" name="action" value="increase"
                                                        class="w-8 h-8 flex items-center  justify-center rounded-full hover:bg-zinc-800 text-zinc-400 hover:text-white transition-all active:scale-90 font-bold text-lg">
                                                        +
                                                    </button>

                                                </div>
                                            </form>

                                            <div class="text-right mt-2">
                                                <p class="text-xl font-black italic ">
                                                    $<%= item.productId.offerPrice * item.quantity %>
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <% }) %>

                                    <% } else { %>

                                        <p class="text-zinc-500 text-center">Cart is empty</p>

                                        <% } %>

                </div>

                <!-- RIGHT SIDE -->
                <div class="lg:w-[400px]">
                    <div class="bg-zinc-900 border border-zinc-800 p-8 rounded-3xl sticky top-32">

                        <h2
                            class="text-xl font-black uppercase tracking-widest mb-8 border-b border-zinc-800 pb-4 text-pink-600">
                            Order Summary
                        </h2>

                        <div class="space-y-4">

                            <div
                                class="flex justify-between text-zinc-400 font-bold uppercase text-[10px] tracking-widest">
                                <span>Subtotal</span>
                                <span class="text-white">$<%= total %></span>
                            </div>

                            <div
                                class="flex justify-between text-zinc-400 font-bold uppercase text-[10px] tracking-widest">
                                <span>Shipping</span>
                                <span class="text-green-500 uppercase">Free</span>
                            </div>

                            <div
                                class="flex justify-between text-zinc-400 font-bold uppercase text-[10px] tracking-widest border-b border-zinc-800 pb-4">
                                <span>Tax (GST)</span>
                                <span class="text-white">$<%= Math.floor(total * 0.09) %></span>
                            </div>

                            <div class="flex justify-between items-center pt-4">
                                <span class="font-black uppercase tracking-widest">Total</span>
                                <span class="text-3xl font-black italic">
                                    $<%= total + Math.floor(total * 0.09) %>
                                </span>
                            </div>

                        </div>

                        <button
                            class="w-full mt-10 bg-pink-600 text-white py-5 rounded-2xl font-black uppercase tracking-[0.2em] text-xs hover:bg-white hover:text-black transition-all shadow-2xl shadow-pink-600/20 active:scale-95">
                            Authorize Payment <i class="ri-arrow-right-line ml-2"></i>
                        </button>

                        <div
                            class="mt-6 flex items-center justify-center gap-4 text-zinc-600 text-[10px] font-bold uppercase tracking-widest">
                            <i class="ri-shield-check-line text-lg"></i> Secure Checkout
                        </div>

                    </div>
                </div>

            </div>
        </div>

        <%- include('../partials/footer') %>

</body>

</html>