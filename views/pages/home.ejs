<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LuxeCart | Luxury Fashion Destination</title>
  <link rel="stylesheet" href="/output.css">
  <style>
    .luxe-font { font-variant: small-caps; }
    .text-outline {
      color: transparent;
      -webkit-text-stroke: 1px white;
    }
    @keyframes scroll {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .animate-ticker {
      display: flex;
      animation: scroll 20s linear infinite;
    }
  </style>
</head>

<body class="bg-white scroll-smooth luxe-font text-gray-900 ">
  <%- include('../partials/nav') %>

  <div class="relative w-full min-h-screen flex items-center overflow-hidden bg-black pt-36">
    <div class="absolute inset-0 bg-cover bg-center " 
         style="background-image:url('/imgs/heroimg.jpg')">
        </div>
    
    <div class="absolute inset-0 bg-gradient-to-r from-black/90 via-black/40 to-transparent"></div>

    <div class="relative z-10 max-w-7xl mx-auto px-6 md:px-10 w-full text-white">
      <div class="max-w-4xl">
        <span class="text-pink-600 font-bold tracking-[0.4em] uppercase text-xs mb-6 block">New Season 2026</span>
        <h1 class="text-6xl sm:text-8xl md:text-[130px] font-black leading-[0.8] tracking-tighter uppercase mb-10 italic">
          Elevate <br> Your <span class="text-outline">Style</span>
        </h1>
        <p class="text-lg md:text-2xl text-gray-300 mb-12 max-w-xl font-light leading-relaxed opacity-90">
          Discover the finest luxury fashion and accessories curated for the modern individual.
        </p>
        <div class="flex flex-wrap gap-5">
          <a href="/shop" 
             class="bg-white text-black px-12 py-5 rounded-full font-bold uppercase tracking-widest text-xs hover:bg-pink-600 hover:text-white transition-all duration-500 shadow-2xl transform hover:-translate-y-1">
            Shop Collection
          </a>
          <a href="/#about-section" class="border border-white/30 backdrop-blur-md text-white px-12 py-5 rounded-full font-bold uppercase tracking-widest text-xs hover:bg-white hover:text-black transition-all duration-500">
            Our Story
          </a>
        </div>
      </div>
    </div>
  </div>

  <section class="bg-black py-6 border-y border-white/10 overflow-hidden">
    <div class="flex justify-around space-x-4  uppercase tracking-[0.3em] text-[10px] font-bold text-gray-400">
      <div class="flex items-center gap-2 pl-4">⭐ 10K+ Happy Customers</div>
      <div class="flex items-center gap-2">👕 Premium Fabric</div>
      <div class="flex items-center gap-2">🚚 Fast Delivery</div>
      <div class="flex items-center gap-2 pr-4">🛡️ Trusted Store</div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="grid md:grid-cols-12 gap-12 items-center">
        <div class="md:col-span-5 space-y-6">
          <h2 class="text-xs font-bold text-pink-600 tracking-[0.5em] uppercase">Trending Now</h2>
          <h3 class="text-5xl md:text-7xl font-black uppercase italic leading-none tracking-tighter">
            Urban <br> Essence
          </h3>
          <p class="text-gray-500 text-lg">Express who you are through our latest streetwear and aesthetic drops.</p>
          <a href="/shop/genz" class="inline-block text-sm font-bold border-b-2 border-black pb-1 hover:text-pink-600 hover:border-pink-600 transition-all uppercase tracking-widest">
            Explore Trends →
          </a>
        </div>
        <div class="md:col-span-7 grid grid-cols-2 gap-4">
          <div class="space-y-4">
            <img src="/models/model1.jpeg" class="w-full h-80 object-cover rounded-2xl shadow-2xl transition hover:grayscale">
            <img src="/models/model2.jpeg" class="w-full h-60 object-cover rounded-2xl shadow-lg">
          </div>
          <div class="pt-12">
            <img src="/models/model3.jpeg" class="w-full h-[450px] object-cover rounded-2xl shadow-2xl">
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="px-4 md:px-10 py-10">
    <div class="relative h-[70vh] md:h-[80vh] rounded-[50px] overflow-hidden group shadow-2xl">
      <div class="absolute inset-0 bg-fixed bg-cover bg-center transition-transform duration-700 group-hover:scale-110" 
           style="background-image: url('/bg2.jpeg');"></div>
      <div class="absolute inset-0 bg-black/50 group-hover:bg-black/30 transition-all duration-700"></div>
      
      <div class="relative h-full flex flex-col items-center justify-center text-center text-white px-6">
        <div class="bg-yellow-400 text-black px-6 py-1 rounded-full text-[10px] font-black tracking-widest mb-8 uppercase">Limited Time Offer</div>
        <h2 class="text-9xl md:text-[220px] font-black leading-none tracking-tighter italic opacity-90">25%</h2>
        <h2 class="text-4xl md:text-6xl font-black tracking-[0.2em] uppercase">Discount</h2>
        <p class="mt-6 text-lg md:text-xl font-light tracking-widest opacity-80 uppercase">First sign up bonus • Code: LUXE25</p>
        <button class="mt-12 bg-white text-black px-14 py-5 rounded-full font-bold hover:bg-pink-600 hover:text-white transition-all shadow-2xl uppercase tracking-widest text-xs">
          Claim Voucher Now
        </button>
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-6 text-center">
      <h2 class="text-xs font-bold text-gray-400 tracking-[1em] uppercase mb-4">Our Products</h2>
      <h3 class="text-5xl font-black uppercase italic mb-16 italic tracking-tighter">Featured Style</h3>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <% [4, 5, 6].forEach(num => { %>
          <div class="group relative overflow-hidden rounded-3xl aspect-[3/4] shadow-lg">
            <img src="/models/model<%= num %>.jpg" class="w-full h-full object-cover group-hover:scale-110 transition duration-700">
            <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-8">
              <a href="/shop" class="w-full bg-white text-black py-4 rounded-xl font-bold uppercase tracking-widest text-[10px]">Shop This Look</a>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </section>

  <section id="about-section" class="bg-gray-50 py-24">
    <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-20 items-center">
      <div class="relative group">
        <div class="absolute -top-4 -left-4 w-full h-full border-2 border-pink-600 rounded-3xl group-hover:top-0 group-hover:left-0 transition-all"></div>
        <img src="/imgs/about/about.jpg" class="rounded-3xl shadow-2xl relative z-10 transition group-hover:-translate-y-2">
      </div>
      <div class="space-y-8">
        <h2 class="text-xs font-bold text-pink-600 tracking-[0.5em] uppercase">The Brand</h2>
        <h3 class="text-4xl md:text-6xl font-black leading-tight uppercase italic tracking-tighter">Luxury for <br> Everyone</h3>
        <p class="text-gray-500 text-lg leading-relaxed font-light italic">
          "LuxeCart is more than a store. It's a statement. We deliver premium quality that feels luxurious yet remains accessible."
        </p>
        <div class="flex gap-12 pt-8 border-t border-gray-200">
          <div><p class="text-4xl font-black">10K+</p><p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Fans</p></div>
          <div><p class="text-4xl font-black">4.9★</p><p class="text-[10px] text-gray-400 font-bold uppercase tracking-widest">Rating</p></div>
        </div>
      </div>
    </div>
  </section>
 

  
  <button onclick="window.scrollTo({top:0, behavior:'smooth'})" 
          class="flex items-center gap-3 mx-auto my-24 px-12 py-5 bg-black text-white text-[10px] font-bold rounded-full 
                 shadow-2xl hover:bg-pink-700 hover:-translate-y-2 transition-all duration-500 uppercase tracking-widest">
    <span>↑</span> Back to Top
  </button>

  <%- include('../partials/footer') %>
</body>
</html>