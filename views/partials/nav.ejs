<nav
    class="scroll top-0 w-full z-[100] bg-[#1e232f] backdrop-blur-md border-b border-white/10 px-6 md:px-10 py-4 transition-all duration-300">
    <div class="max-w-7xl mx-auto flex items-center justify-between">

        <div class="text-2xl md:text-3xl font-black tracking-[0.2em]  italic text-white">
            <a href="/" class="hover:text-pink-600 [font-variant:small-caps] transition">Luxe<span
                    class="font-light">Cart</span></a>
        </div>

        <div
            class="hidden lg:flex items-center space-x-10 text-[10px] font-bold uppercase tracking-[0.3em] text-gray-300">
            <a href="/" class="hover:text-white transition relative group">
                Home
                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-pink-600 transition-all group-hover:w-full"></span>
            </a>
            <a href="/#about-section" class="hover:text-white transition relative group">
                About
                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-pink-600 transition-all group-hover:w-full"></span>
            </a>
            <a href="/collection" class="hover:text-white transition relative group">
                Collection
                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-pink-600 transition-all group-hover:w-full"></span>
            </a>
            <a href="/shop" class="hover:text-white transition relative group">
                Shop
                <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-pink-600 transition-all group-hover:w-full"></span>
            </a>
        </div>

        <div class="flex items-center gap-6">
            <div class="hidden md:relative md:block group">
                <form action="/search" method="GET">
                    <input type="text" name="q" placeholder="SEARCH COLLECTION..."
                        class="bg-white/5 border border-white/10 px-10 py-2 rounded-full text-xs text-white outline-none focus:border-pink-600 focus:w-64 transition-all duration-500 w-48 placeholder:text-gray-500 uppercase tracking-widest">

                    <button type="submit" class="absolute left-4 top-1/2 -translate-y-1/2 outline-none">
                        <svg xmlns="http://www.w3.org/2000/svg"
                            class="w-4 h-4 text-gray-400 group-focus-within:text-pink-600 transition-colors" fill="none"
                            viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M21 21l-4.35-4.35M10 18a8 8 0 100-16 8 8 0 000 16z" />
                        </svg>
                    </button>
                </form>
            </div>

            <div class="hidden sm:flex items-center gap-3">
                <% if (user) { %>
                    <div class="flex items-center gap-4">
                        <a href="/profile" class="group flex items-center gap-3">
                            <div class="relative">
                                <div
                                    class="w-9 h-9 rounded-full bg-zinc-900 flex items-center justify-center text-[11px] font-black text-amber-500 border border-amber-500/50 group-hover:border-amber-400 transition-all shadow-[0_0_15px_rgba(245,158,11,0.2)]">
                                    <%= user.name.charAt(0).toUpperCase() %>
                                </div>
                                <span
                                    class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-amber-500 border-2 border-[#1e232f] rounded-full"></span>
                            </div>

                            <div class="hidden md:flex flex-col items-start leading-none">
                                <div class="flex items-center gap-1">
                                    <i
                                        class="ri-user-3-line text-zinc-500 text-xs group-hover:text-amber-500 transition-colors"></i>

                                </div>
                                <span
                                    class="text-[9px] text-zinc-500 font-bold uppercase tracking-tighter mt-1 group-hover:text-amber-500 transition-colors">
                                    <%= user.name.split(' ')[0] %>
        </span>
    </div>
</a>
                       <a href="/logout" 
   class="flex items-center gap-2 px-4 py-2 border border-zinc-800 rounded-full text-[10px] font-black text-zinc-500 uppercase tracking-widest hover:border-red-500/50 hover:text-red-500 hover:bg-red-500/5 transition-all duration-300 active:scale-95">
    <i class="ri-logout-circle-r-line text-sm"></i>
    Logout
</a>
                    </div>
                    <% } else { %>
                        <a href="/login"
                            class="text-[10px] font-bold text-white uppercase tracking-widest hover:text-pink-600 transition">Login</a>
                        <a href="/signup"
                            class="bg-white text-black px-6 py-2.5 rounded-full text-[10px] font-bold uppercase tracking-widest hover:bg-pink-600 hover:text-white transition-all shadow-xl">
                            Sign Up
                        </a>
                        <% } %>
            </div>

            <button class="lg:hidden text-white" onclick="toggleMenu()">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
                </svg>
            </button>
        </div>
    </div>

    <div id="mobileMenu"
        class="fixed inset-0 bg-black/95 z-[200] flex flex-col items-center justify-center space-y-8 opacity-0 pointer-events-none transition-all duration-500">
        <button class="absolute top-10 right-10 text-white" onclick="toggleMenu()">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24"
                stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
        </button>
        <a href="/" class="text-4xl font-black text-white italic tracking-tighter hover:text-pink-600"
            onclick="toggleMenu()">HOME</a>
        <a href="/about" class="text-4xl font-black text-white italic tracking-tighter hover:text-pink-600"
            onclick="toggleMenu()">ABOUT</a>
        <a href="/collection" class="text-4xl font-black text-white italic tracking-tighter hover:text-pink-600"
            onclick="toggleMenu()">COLLECTION</a>
        <a href="/shop" class="text-4xl font-black text-white italic tracking-tighter hover:text-pink-600"
            onclick="toggleMenu()">SHOP</a>
        <div class="pt-10 flex flex-col gap-4 w-64">
            <a href="/login"
                class="text-center bg-white text-black py-4 rounded-full font-bold uppercase tracking-widest text-xs">Login</a>
            <a href="/signup"
                class="text-center border border-white text-white py-4 rounded-full font-bold uppercase tracking-widest text-xs">Sign
                Up</a>
        </div>
    </div>
</nav>

<script>
    function openNav() {
        document.getElementById("mySidebar").style.width = "250px";
        document.getElementById("main").style.marginRight = "250px";
    }

    function closeNav() {
        document.getElementById("mySidebar").style.width = "0";
        document.getElementById("main").style.marginRight = "0";
    } </script>